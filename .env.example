# OpenJWC runtime environment example
# Copy to .env in deployment environment and replace with real values.

# JWT / auth
OPENJWC_SECRET_KEY=replace-with-strong-random-secret
OPENJWC_JWT_ALGORITHM=HS256

# LanceDB storage location (optional, defaults to data/lancedb)
LANCE_DB_PATH=data/lancedb

# Agent LLM (optional)
LITELLM_API_KEY=
OPENJWC_AGENT_MODEL=openai/gpt-4o-mini
OPENJWC_LLM_TIMEOUT_SECONDS=45

# Proxy (optional)
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
